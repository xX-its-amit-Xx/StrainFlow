// StrainFlow — nextflow.config
// Profiles: local | aws | test
// License: GPL v3.0

manifest {
    name            = 'StrainFlow'
    author          = 'Amit Shenoy'
    homePage        = 'https://github.com/xX-its-amit-Xx/StrainFlow'
    description     = 'Strain-resolved shotgun metagenomics pipeline'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.10.0'
    version         = '1.0.0'
}

// ── default parameters ────────────────────────────────────────────────────────
params {
    // I/O
    input           = null                        // samplesheet CSV (required)
    outdir          = 'results'

    // Host removal
    host_index      = 's3://strainflow-refs/GRCh38/GRCh38_noalt_bowtie2'  // bowtie2 index prefix

    // Kraken2 / Bracken
    kraken2_db      = 's3://strainflow-refs/kraken2/k2_standard_20240605'
    bracken_length  = 150
    bracken_level   = 'S'                         // Species

    // MetaPhlAn4 / StrainPhlAn
    metaphlan_db    = 's3://strainflow-refs/metaphlan/mpa_vJan21_CHOCOPhlAnSGB_202103'
    strainphlan_clades = null                     // comma-separated clade list; null = all detected

    // inStrain
    instrain_db     = 's3://strainflow-refs/instrain/MIDAS_v1.3.2.idb'

    // Assembly
    assembler       = 'megahit'                   // 'megahit' | 'metaspades'
    megahit_preset  = 'meta-sensitive'

    // Binning
    metabat2_min_contig = 1500

    // CheckM / GTDB-Tk
    checkm_db       = null                        // set to local/S3 path
    enable_gtdbtk   = false                       // off by default (large DB ~75 GB)
    gtdbtk_db       = null

    // HUMAnN3
    humann3_nt_db   = 's3://strainflow-refs/humann3/chocophlan'
    humann3_prot_db = 's3://strainflow-refs/humann3/uniref90_annotated_v201901'

    // MultiQC
    multiqc_config  = "${projectDir}/assets/multiqc_config.yml"

    // Resource labels (used with withLabel)
    max_memory      = '128.GB'
    max_cpus        = 32
    max_time        = '72.h'

    // Misc
    publish_dir_mode = 'copy'
    help             = false
    version          = false
}

// ── process defaults ──────────────────────────────────────────────────────────
process {
    errorStrategy = { task.exitStatus in [104, 134, 137, 139, 143, 247] ? 'retry' : 'finish' }
    maxRetries    = 2

    // Fine-grained resource labels referenced in every module
    withLabel: 'small' {
        cpus   = 2
        memory = '8.GB'
        time   = '2.h'
    }
    withLabel: 'medium' {
        cpus   = 8
        memory = '32.GB'
        time   = '8.h'
    }
    withLabel: 'large' {
        cpus   = 16
        memory = '64.GB'
        time   = '24.h'
    }
    withLabel: 'xlarge' {
        cpus   = 32
        memory = '128.GB'
        time   = '48.h'
    }
}

// ── profiles ──────────────────────────────────────────────────────────────────
profiles {

    // ── local: Docker on developer laptop / single node ───────────────────────
    local {
        docker {
            enabled    = true
            runOptions = '-u $(id -u):$(id -g)'   // avoid root-owned output files
        }
        process {
            withLabel: 'small'  { cpus = 2;  memory = '4.GB';  time = '2.h' }
            withLabel: 'medium' { cpus = 4;  memory = '16.GB'; time = '4.h' }
            withLabel: 'large'  { cpus = 8;  memory = '32.GB'; time = '12.h' }
            withLabel: 'xlarge' { cpus = 16; memory = '64.GB'; time = '24.h' }
        }
        params {
            host_index      = "${HOME}/refs/GRCh38/GRCh38_noalt_bowtie2"
            kraken2_db      = "${HOME}/refs/kraken2/k2_standard_20240605"
            metaphlan_db    = "${HOME}/refs/metaphlan/mpa_vJan21_CHOCOPhlAnSGB_202103"
            instrain_db     = "${HOME}/refs/instrain/MIDAS_v1.3.2.idb"
            humann3_nt_db   = "${HOME}/refs/humann3/chocophlan"
            humann3_prot_db = "${HOME}/refs/humann3/uniref90_annotated_v201901"
        }
    }

    // ── aws: AWS Batch + S3 work directory ────────────────────────────────────
    aws {
        // Work directory on S3 — no local disk I/O between tasks
        workDir = "s3://${System.getenv('NXF_S3_BUCKET') ?: 'strainflow-work'}/work"  // cost: pay per PUT/GET

        aws {
            region = 'us-east-1'
            batch {
                cliPath    = '/home/ec2-user/miniconda/bin/aws'
                volumes    = '/tmp'
                maxTransferAttempts = 3           // retry S3 data-staging on transient failures
            }
        }

        process {
            executor = 'awsbatch'
            // Spot queue for interruptible workloads — up to 90 % cheaper than On-Demand
            queue = 'strainflow-spot-queue'       // cost: spot price vs on-demand

            withLabel: 'small' {
                queue  = 'strainflow-spot-queue'
                cpus   = 2
                memory = '8.GB'
                time   = '2.h'
                // Retry on spot reclaim (exit 1) with 1-min back-off
                errorStrategy = { sleep(Math.pow(2, task.attempt) * 60 as long); return 'retry' }
                maxRetries    = 3
            }
            withLabel: 'medium' {
                queue  = 'strainflow-spot-queue'  // cost: c5.2xlarge ≈ $0.17/hr spot
                cpus   = 8
                memory = '32.GB'
                time   = '8.h'
                errorStrategy = { sleep(Math.pow(2, task.attempt) * 60 as long); return 'retry' }
                maxRetries    = 3
            }
            withLabel: 'large' {
                queue  = 'strainflow-spot-queue'  // cost: r5.4xlarge ≈ $0.28/hr spot
                cpus   = 16
                memory = '64.GB'
                time   = '24.h'
                errorStrategy = { sleep(Math.pow(2, task.attempt) * 120 as long); return 'retry' }
                maxRetries    = 3
            }
            withLabel: 'xlarge' {
                // On-demand for memory-intensive MAG steps to avoid costly re-runs
                queue  = 'strainflow-ondemand-queue'  // cost: r5.8xlarge ≈ $2.02/hr
                cpus   = 32
                memory = '128.GB'
                time   = '48.h'
                maxRetries = 1
            }
        }

        docker {
            enabled = true
        }
    }

    // ── test: tiny synthetic data, runs in <10 min, used by CI ───────────────
    test {
        params {
            input           = "${projectDir}/data/test/samplesheet.csv"
            outdir          = 'test-results'
            host_index      = "${projectDir}/data/test/refs/GRCh38_chr22_mini"
            kraken2_db      = "${projectDir}/data/test/refs/kraken2_mini"
            metaphlan_db    = "${projectDir}/data/test/refs/metaphlan_mini"
            instrain_db     = "${projectDir}/data/test/refs/instrain_mini.idb"
            humann3_nt_db   = "${projectDir}/data/test/refs/chocophlan_mini"
            humann3_prot_db = "${projectDir}/data/test/refs/uniref90_mini"
            enable_gtdbtk   = false
            max_memory      = '8.GB'
            max_cpus        = 4
            max_time        = '1.h'
        }
        docker {
            enabled = true
        }
        process {
            withLabel: 'small'  { cpus = 1; memory = '2.GB';  time = '30.min' }
            withLabel: 'medium' { cpus = 2; memory = '4.GB';  time = '30.min' }
            withLabel: 'large'  { cpus = 2; memory = '6.GB';  time = '30.min' }
            withLabel: 'xlarge' { cpus = 4; memory = '8.GB';  time = '30.min' }
        }
    }

    // ── conda fallback (no Docker required) ───────────────────────────────────
    conda_env {
        conda.enabled = true
        process {
            conda = "${projectDir}/conda/environment.yml"
        }
    }
}

// ── helper: cap resources to cluster/node maximums ───────────────────────────
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else return obj
        } catch (all) { return obj }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else return obj
        } catch (all) { return obj }
    } else if (type == 'cpus') {
        try { return Math.min(obj as int, params.max_cpus as int) }
        catch (all) { return obj }
    }
}
